<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Inventario</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-8">
<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">Panel de Control de Inventario</h1>

    <div class="grid grid-cols-2 gap-4 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-blue-500">
            <h2 class="text-gray-500 text-sm uppercase font-bold">Total de Productos Registrados</h2>
            <p class="text-3xl font-bold text-gray-800"><%= totalProductos %></p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-green-500">
            <h2 class="text-gray-500 text-sm uppercase font-bold">Valor Total del Inventario</h2>
            <p class="text-3xl font-bold text-gray-800">$<%= Number(valorInventario).toLocaleString('es-EC', {minimumFractionDigits: 2}) %></p>
        </div>
    </div>

    <div class="grid grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-md">
            <h2 class="text-xl font-bold text-red-600 mb-4 flex items-center">
                ⚠️ Alerta de Bajo Stock (< 5 unidades)
            </h2>
            <ul>
                <% if (bajoStock && bajoStock.length > 0) { %>
                    <% bajoStock.forEach(producto => { %>
                        <li class="border-b py-2 flex justify-between">
                            <span><%= producto.nombre %></span>
                            <span class="bg-red-100 text-red-800 text-xs font-bold px-2 py-1 rounded">Quedan <%= producto.cantidad %></span>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li class="text-gray-500 italic">No hay productos con bajo stock.</li>
                <% } %>
            </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
            <h2 class="text-xl font-bold text-gray-800 mb-4">🏆 Top 5 Mayor Valor en Inventario</h2>
            <ul>
                <% if (topValiosos && topValiosos.length > 0) { %>
                    <% topValiosos.forEach(producto => { %>
                        <li class="border-b py-2 flex justify-between">
                            <span><%= producto.nombre %> <span class="text-gray-400 text-sm">(<%= producto.cantidad %> uds)</span></span>
                            <span class="font-bold text-green-600">$<%= Number(producto.valor_total).toLocaleString('es-EC', {minimumFractionDigits: 2}) %></span>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li class="text-gray-500 italic">No hay productos registrados.</li>
                <% } %>
            </ul>
        </div>
    </div>
</div>
</body>
</html>